{
    "name": "liberusoftware/boilerplate-laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": [
        "laravel",
        "framework"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.5",
        "bezhansalleh/filament-shield": "~4.0",
        "biostate/filament-menu-builder": "^5.0",
        "bursteri/socialstream": "^7.0",
        "filament/filament": "~5.1",
        "filament/spatie-laravel-settings-plugin": "^5.0",
        "guzzlehttp/guzzle": "^7.8",
        "internachi/modular": "^3.0",
        "laravel/framework": "^13.0",
        "laravel/horizon": "^5.0",
        "laravel/jetstream": "^5.1",
        "laravel/octane": "^2.3",
        "laravel/reverb": "^1.0",
        "laravel/sanctum": "^4.0",
        "laravel/tinker": "^3.0",
        "livewire/livewire": "^4.0",
        "spatie/laravel-menu": "^4.2",
        "spatie/laravel-passkeys": "^1.6",
        "spatie/laravel-permission": "^7.0",
        "spiral/roadrunner-cli": "^2.6.0",
        "spiral/roadrunner-http": "^3.3.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "filament/upgrade": "~5.1",
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.14",
        "laravel/sail": "^1.28",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.8",
        "pestphp/pest": "5.x-dev",
        "pestphp/pest-plugin-laravel": "5.x-dev",
        "phpunit/phpunit": "^13.1.8",
        "spatie/laravel-ignition": "^2.4"
    },

    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Modules\\": "app-modules/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "app/Helpers/locale_helpers.php",
            "app/Helpers/theme_helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ],
        "test": "vendor/bin/pest"
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "platform": {
            "php": "8.5",
            "ext-posix": "1.0"
        },
        "platform-check": false,
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "audit": {
        "ignore": [
            "PKSA-qccq-2pht-gg3w",
            "PKSA-5jz8-6tcw-pbk4"
        ]
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
